<?php
// === LOGIC SECTION (No Output) ===
require_once __DIR__ . '/../../includes/init.php';
require_once __DIR__ . '/functions.php';

$page_title = "Edit Produk";

// Validate ID
$produk_id = (int)get('id');
if (!$produk_id) {
    setMessage('ID produk tidak valid!', 'error');
    redirect('index.php');
}

$produk = getProdukById($produk_id);
if (!$produk) {
    setMessage('Produk tidak ditemukan!', 'error');
    redirect('index.php');
}

$onesender_accounts = getOneSenderAccounts();
$errors = [];

if (isPost()) {
    $data = [
        'nama' => post('nama'),
        'deskripsi' => post('deskripsi'),
        'harga' => post('harga'),
        'link_akses' => clean(post('link_akses')),
        'onesender_account' => clean(post('onesender_account')),
        'admin_wa' => clean(post('admin_wa')),
        'meta_pixel_id' => clean(post('meta_pixel_id')),
        'conversion_api_token' => clean(post('conversion_api_token')),
        'tracking_aktif' => post('tracking_aktif') ? 1 : 0
    ];
    
    $errors = validateProdukData($data);
    
    if (empty($errors)) {
        if (updateProduk($produk_id, $data)) {
            setMessage('Produk berhasil diupdate!', 'success');
            redirect('index.php');
        } else {
            $errors[] = 'Gagal mengupdate produk. Silakan coba lagi.';
        }
    }
} else {
    // Set form data from database
    $_POST = $produk;
}

// === PRESENTATION SECTION ===
require_once __DIR__ . '/../../includes/header.php';
require_once __DIR__ . '/../../includes/sidebar.php';
?>

